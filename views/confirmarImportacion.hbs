<div class="containerConfirm">
  <div class="titleConfirm">
    <h2>Confirmar Productos Extraídos</h2>
    <p>Revisa que los datos sean correctos antes de guardarlos definitivamente.</p>
  </div>
  <form action="/importar/confirmar" method="POST" class="formConfirm">
    <table class="tableConfirm" id="tableConfirm">
      <thead>
        <tr>
          <th>Nombre del Producto</th>
          <th>Marca</th>
          <th>Precio ($)</th>
          <th>Stock</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        {{#each productos}}
          <tr class="rowConfirm">
            <td>
              <input
                type="text"
                name="productos[{{@index}}][nombre]"
                value="{{this.nombre}}"
                class="input-edit"
              />
            </td>
            <td>
              <select
                name="productos[{{@index}}][marca]"
                class="input-edit"
                required
              >
                <option value="" disabled selected>Elegir marca...</option>
                  {{#each ../marcas}} 
                    <option value="{{this._id}}">
                      {{this.nombre}}
                    </option>
                  {{/each}}
              </select>
            </td>
            <td>
              <input
                type="number"
                step="0.01"
                name="productos[{{@index}}][precio]"
                value="{{this.precio}}"
                class="input-edit"
              />
            </td>
            <td>
              <input
                type="number"
                name="productos[{{@index}}][stock]"
                value="{{this.stock}}"
                class="input-edit"
              />
            </td>
            <td>
              <button
                type="button"
                class="btn-remove-row"
                title="Eliminar de la lista"
              >
                🗑️
              </button>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>

    <div class="actionsConfirm">
      <a href="/importar" class="btnCancel">Cancelar</a>
      <button type="submit" class="btn">
        Guardar en Base de Datos
      </button>
    </div>
  </form>
</div>

<script src="/js/confirmImport.js"></script>